local TPWalkEnabled = false
local TPWalkSpeed = 6 -- ความเร็วเริ่มต้น (ช้าลงมากแล้ว)

local currentVelocity = Vector3.new()

RunService.RenderStepped:Connect(function(dt)
    if not TPWalkEnabled then 
        currentVelocity = Vector3.new()
        return 
    end

    local char = LocalPlayer.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    local moveDir = hum.MoveDirection

    if moveDir.Magnitude > 0 then
        -- คำนวณเป้าหมายความเร็ว
        local targetVelocity = moveDir.Unit * TPWalkSpeed
        
        -- ทำให้มันสมูท (lerp)
        currentVelocity = currentVelocity:Lerp(targetVelocity, 0.15)
        
        hrp.CFrame = hrp.CFrame + (currentVelocity * dt * 60)
    else
        -- ค่อย ๆ หยุด
        currentVelocity = currentVelocity:Lerp(Vector3.new(), 0.2)
    end
end)

