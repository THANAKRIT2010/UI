-- ===== ดึงข้อมูลเพลงจาก Player =====
local function GetMusicInfoFromPlayer(player)
    if not player or not player.Character then
        return nil
    end

    for _,v in pairs(player.Character:GetDescendants()) do
        if v:IsA("Sound") and v.SoundId ~= "" then
            
            local soundId = v.SoundId

            -- ดึง ID แบบกันบัค
            local id = string.match(soundId, "rbxassetid://(%d+)")
            if not id then
                id = string.match(soundId, "%d%d%d%d%d%d+")
            end

            if id and #id > 5 then
                
                local success, info = pcall(function()
                    return MarketplaceService:GetProductInfo(tonumber(id))
                end)

                if success and info then
                    return {
                        Id = id,
                        Name = info.Name or "ไม่พบชื่อ",
                        Creator = (info.Creator and info.Creator.Name) or "ไม่ทราบ"
                    }
                else
                    return {
                        Id = id,
                        Name = "ไม่สามารถดึงชื่อเพลง",
                        Creator = "ไม่ทราบ"
                    }
                end
            end
        end
    end

    return nil
end

-- ===== หาคนใกล้ที่สุด =====
local function GetNearestPlayer()
    local nearest = nil
    local shortestDistance = math.huge

    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return nil
    end

    local myPos = LocalPlayer.Character.HumanoidRootPart.Position

    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            
            local targetPos = plr.Character.HumanoidRootPart.Position
            local distance = (myPos - targetPos).Magnitude

            if distance < shortestDistance then
                shortestDistance = distance
                nearest = plr
            end
        end
    end

    return nearest
end

